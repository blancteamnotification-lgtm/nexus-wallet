# Railway — один сервис (web + Telegram webhook)

# Вариант 1: полный URL
WEBAPP_URL=https://your-app.up.railway.app
NEXT_PUBLIC_WEBAPP_URL=https://your-app.up.railway.app

# Вариант 2: только домен (https:// добавится автоматически)
# WEBAPP_URL=your-app.up.railway.app

# Вариант 3: на Railway можно не задавать WEBAPP_URL —
# используется RAILWAY_PUBLIC_DOMAIN автоматически

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Amplitude — https://app.amplitude.com → Settings → Projects → API Key
NEXT_PUBLIC_AMPLITUDE_API_KEY=your_amplitude_api_key

# BotFather: /setdomain → домен без https://
